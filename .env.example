# Логин и токен для входа в /admin.
# Скопируйте этот файл в .env.local и задайте реальные значения.

# Логин администратора (произвольная строка)
ADMIN_LOGIN=admin

# Токен/пароль администратора. Должен быть длинным и случайным.
# Можно сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=replace_me_with_a_long_random_token

# Vercel Blob — автоматически добавляются при подключении Blob Store в Vercel Dashboard.
# Нужны для хранения загруженных файлов и проверки вебхуков от Vercel Blob.
BLOB_STORE_ID=
BLOB_WEBHOOK_PUBLIC_KEY=
